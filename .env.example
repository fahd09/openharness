# Claude Code Core — Environment Variables
# Copy this file to .env and fill in your keys.

# ── LLM Provider ────────────────────────────────────────────────────
# Which LLM provider to use. Default: "anthropic"
# Options: anthropic, openai, openai-compat, gemini
# LLM_PROVIDER=anthropic

# ── Anthropic (default provider) ────────────────────────────────────
# Required when LLM_PROVIDER=anthropic (default)
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Gemini ───────────────────────────────────────────────────
# Required when LLM_PROVIDER=gemini (or LLM_PROVIDER=google)
# Get your key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=...
# GOOGLE_API_KEY=...    # alias for GEMINI_API_KEY

# ── OpenAI / OpenAI-compatible ──────────────────────────────────────
# Required when LLM_PROVIDER=openai or openai-compat
# OPENAI_API_KEY=sk-...

# Base URL for OpenAI-compatible APIs (default: https://api.openai.com/v1)
# Examples:
#   Together AI:  https://api.together.xyz/v1
#   Groq:         https://api.groq.com/openai/v1
#   Ollama:       http://localhost:11434/v1
#   LM Studio:    http://localhost:1234/v1
#   Qwen:         https://dashscope.aliyuncs.com/compatible-mode/v1
#   Mistral:      https://api.mistral.ai/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# Default model for OpenAI provider (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# ── Web Search (at least one recommended) ────────────────────────────
# Brave Search API — free: 2,000 queries/month
# Sign up: https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# Serper.dev (Google results) — free: 2,500 queries
# Sign up: https://serper.dev/
SERPER_API_KEY=

# ── Optional ─────────────────────────────────────────────────────────
# Max output tokens (default: 16384)
# CLAUDE_CODE_MAX_OUTPUT_TOKENS=16384

# Extended thinking budget in tokens (min 1024)
# Supported by: Anthropic Claude (all models) and Google Gemini (2.5+)
# - Anthropic: passed as token budget directly
# - Gemini 2.5: passed as token budget (thinkingBudget)
# - Gemini 3.x: mapped to level — <=1024: low, <=8192: medium, >8192: high
# - OpenAI: not supported (o1/o3 reason internally, not configurable)
# CLAUDE_CODE_THINKING_BUDGET=10000

# Max retries for API calls (default: 10)
# CLAUDE_CODE_MAX_RETRIES=10

# API timeout in ms (default: 600000)
# API_TIMEOUT_MS=600000

# Tool concurrency limit (default: 10)
# CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY=10
